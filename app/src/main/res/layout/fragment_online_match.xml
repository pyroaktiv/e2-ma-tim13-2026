<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <include
        android:id="@+id/gameHeader"
        layout="@layout/layout_game_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ViewFlipper
        android:id="@+id/flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/gameHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 0: MATCHMAKING -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvMmStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Povezivanje..."
                android:textSize="18sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMmCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Otkaži" />
        </LinearLayout>

        <!-- 1: KO ZNA ZNA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:text="" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvKzzInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textStyle="italic"
                android:layout_marginBottom="8dp"
                android:text="" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnsA"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnsB"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnsC"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnsD"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- 2: SPOJNICE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvCriterion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="16sp"
                android:text="" />

            <TextView
                android:id="@+id/tvTurnInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textStyle="italic"
                android:layout_marginBottom="8dp"
                android:text="" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnL0" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="8dp" android:insetTop="0dp" android:insetBottom="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnL1" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="8dp" android:insetTop="0dp" android:insetBottom="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnL2" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="8dp" android:insetTop="0dp" android:insetBottom="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnL3" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="8dp" android:insetTop="0dp" android:insetBottom="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnL4" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:insetTop="0dp" android:insetBottom="0dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnR0" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="8dp" android:insetTop="0dp" android:insetBottom="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnR1" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="8dp" android:insetTop="0dp" android:insetBottom="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnR2" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="8dp" android:insetTop="0dp" android:insetBottom="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnR3" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginBottom="8dp" android:insetTop="0dp" android:insetBottom="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnR4" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:insetTop="0dp" android:insetBottom="0dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 3: RESULT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:text="" />

            <TextView
                android:id="@+id/tvResultScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"
                android:text="" />

            <TextView
                android:id="@+id/tvResultStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginBottom="32dp"
                android:text="" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResultBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nazad na meni" />
        </LinearLayout>

        <!-- 4: SKOČKO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvSkockoTurn"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textStyle="italic" android:layout_marginBottom="6dp" android:text="" />

            <!-- 6 guess rows + bonus row, built programmatically -->
            <LinearLayout
                android:id="@+id/llSkockoGrid"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:layout_marginTop="6dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSym0" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="" app:icon="@drawable/ic_skocko" app:iconGravity="textTop" app:iconSize="26dp" android:insetTop="0dp" android:insetBottom="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSym1" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="" app:icon="@drawable/ic_kvadrat" app:iconGravity="textTop" app:iconSize="26dp" android:insetTop="0dp" android:insetBottom="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSym2" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="" app:icon="@drawable/ic_krug" app:iconGravity="textTop" app:iconSize="26dp" android:insetTop="0dp" android:insetBottom="0dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSym3" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="" app:icon="@drawable/ic_srce" app:iconGravity="textTop" app:iconSize="26dp" android:insetTop="0dp" android:insetBottom="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSym4" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="" app:icon="@drawable/ic_trougao" app:iconGravity="textTop" app:iconSize="26dp" android:insetTop="0dp" android:insetBottom="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSym5" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="" app:icon="@drawable/ic_zvezda" app:iconGravity="textTop" app:iconSize="26dp" android:insetTop="0dp" android:insetBottom="0dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="6dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSkockoBack" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="⌫" android:layout_marginEnd="8dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSkockoSubmit" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Potvrdi" />
            </LinearLayout>
        </LinearLayout>

        <!-- 5: KORAK PO KORAK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvKorakTurn"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textStyle="italic" android:text="" />
            <TextView
                android:id="@+id/tvKorakPoints"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textStyle="bold" android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="8dp" android:text="" />

            <ScrollView
                android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <TextView
                    android:id="@+id/tvKorakClues"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="17sp" android:lineSpacingMultiplier="1.3" android:text="" />
            </ScrollView>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:hint="Tvoje rešenje" android:layout_marginTop="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etKorakGuess"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="text" android:imeOptions="actionDone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKorakSubmit"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Pogodi" android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 6: MOJ BROJ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvMbTurn"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textStyle="italic" android:text="" />

            <TextView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:text="Traženi broj:" android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tvMbTarget"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textSize="40sp" android:textStyle="bold"
                android:textColor="?attr/colorPrimary" android:text="—" />

            <TextView
                android:id="@+id/tvMbExpr"
                android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                android:gravity="center" android:textSize="22sp" android:background="@drawable/bg_outlined_box"
                android:padding="8dp" android:layout_marginVertical="8dp" android:text="" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbN0" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbN1" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbN2" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbN3" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbN4" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbN5" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbPlus" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="+" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbMinus" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="−" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbMul" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="×" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbDiv" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="÷" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbLPar" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="(" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbRPar" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text=")" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbBack" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="⌫" android:layout_marginEnd="8dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMbSubmit" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Potvrdi" />
            </LinearLayout>
        </LinearLayout>

        <!-- 7: ASOCIJACIJE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvAsoTurn"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textStyle="italic" android:layout_marginBottom="6dp" android:text="" />

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                android:orientation="horizontal" android:baselineAligned="false">

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvAsoCol0" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textStyle="bold" android:text="A" android:textColor="?attr/colorPrimary" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnAso0_0" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="?" android:textSize="11sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" android:layout_marginBottom="3dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnAso0_1" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="?" android:textSize="11sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" android:layout_marginBottom="3dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnAso0_2" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="?" android:textSize="11sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" android:layout_marginBottom="3dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnAso0_3" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="?" android:textSize="11sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnAsoSolve0" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Reši A" android:textSize="10sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:layout_marginHorizontal="2dp">
                    <TextView android:id="@+id/tvAsoCol1" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textStyle="bold" android:text="B" android:textColor="?attr/colorPrimary" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnAso1_0" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="?" android:textSize="11sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" android:layout_marginBottom="3dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnAso1_1" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="?" android:textSize="11sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" android:layout_marginBottom="3dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnAso1_2" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="?" android:textSize="11sp" android:insetTop="0dp" android:insetBottom="0dp" android:paddingHorizontal="0dp" android:layout_marginBottom="3dp" />
