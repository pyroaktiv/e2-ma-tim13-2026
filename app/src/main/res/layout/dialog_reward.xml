<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieReward"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:lottie_rawRes="@raw/reward_animation"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvRewardTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvRewardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reward_title"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="#FF212121"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/lottieReward"
        app:layout_constraintBottom_toTopOf="@id/tvRewardRank"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvRewardRank"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="#FF424242"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvRewardTitle"
        app:layout_constraintBottom_toTopOf="@id/tvRewardTokens"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvRewardTokens"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="#FFB8860B"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvRewardRank"
        app:layout_constraintBottom_toTopOf="@id/btnDismiss"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDismiss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reward_dismiss"
        app:layout_constraintTop_toBottomOf="@id/tvRewardTokens"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
