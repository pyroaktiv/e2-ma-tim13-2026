<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/header_bg_gray"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvHeaderTokens"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tokeni: 5"
            android:textColor="@android:color/black"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvHeaderLeague"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Liga 1"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:layout_marginHorizontal="16dp"/>

        <TextView
            android:id="@+id/tvHeaderStars"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Zvezde: 120"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:gravity="end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/tvPlayer1Score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="8dp"
            android:text="Igrač 1\n0"
            android:textColor="@color/player_blue"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvGameTimer"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_circle_timer"
            android:text="60"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvPlayer2Score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="8dp"
            android:text="Igrač 2\n0"
            android:textColor="@color/player_red"
            android:gravity="center"/>
    </LinearLayout>
</LinearLayout>