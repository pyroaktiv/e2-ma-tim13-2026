<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/game_navigation"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="rs.tim13.slagalica.core.ui.HomeFragment"
        android:label="Slagalica"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_match"
            app:destination="@id/matchHostFragment" />
        <action
            android:id="@+id/action_home_to_profil"
            app:destination="@id/profilFragment" />
        <action
            android:id="@+id/action_home_to_notifications"
            app:destination="@id/notificationsFragment" />
        <action
            android:id="@+id/action_home_to_challenges"
            app:destination="@id/challengeListFragment" />
    </fragment>

    <fragment
        android:id="@+id/matchHostFragment"
        android:name="rs.tim13.slagalica.match.ui.MatchHostFragment"
        android:label="Partija"
        tools:layout="@layout/fragment_match_host">
        <argument
            android:name="mode"
            app:argType="string"
            android:defaultValue="SOLO" />
        <argument
            android:name="challengeId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/challengeListFragment"
        android:name="rs.tim13.slagalica.izazov.ui.ChallengeListFragment"
        android:label="@string/challenge_screen_title"
        tools:layout="@layout/fragment_challenge_list">
        <action
            android:id="@+id/action_challengeList_to_challengeLobby"
            app:destination="@id/challengeLobbyFragment" />
    </fragment>

    <fragment
        android:id="@+id/challengeLobbyFragment"
        android:name="rs.tim13.slagalica.izazov.ui.ChallengeLobbyFragment"
        android:label="@string/challenge_lobby_title"
        tools:layout="@layout/fragment_challenge_lobby">
        <argument
            android:name="challenge_id"
            app:argType="string" />
        <action
            android:id="@+id/action_challengeLobby_to_match"
            app:destination="@id/matchHostFragment" />
    </fragment>

    <fragment
        android:id="@+id/profilFragment"
        android:name="rs.tim13.slagalica.profil.ui.ProfilFragment"
        tools:layout="@layout/fragment_profil">
        <action
            android:id="@+id/action_profil_to_resetPassword"
            app:destination="@id/resetPasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="rs.tim13.slagalica.auth.ui.ResetPasswordFragment"
        android:label="@string/reset_password_title"
        tools:layout="@layout/fragment_auth_reset_password" />

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="rs.tim13.slagalica.notifications.ui.NotificationsFragment"
        android:label="Obaveštenja"
        tools:layout="@layout/fragment_notifications" />

</navigation>
