JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
DB_PATH=slagalica.db
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=your_smtp_password
BASE_URL=http://localhost:3000
PORT=3000

# FCM push (spec 11) — opciono. Ako nije podešeno, push je no-op (istorija + in-app WS i dalje rade).
# Ubaci JSON string service-account ključa, ILI putanju do .json fajla preko FCM_SERVICE_ACCOUNT_PATH.
# FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# FCM_SERVICE_ACCOUNT_PATH=./fcm-service-account.json
# FCM_PROJECT_ID=your-firebase-project-id
